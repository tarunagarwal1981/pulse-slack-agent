# Copy this file to ".env" and fill in real values. Never commit .env.
# Where each value comes from is explained in the README.

# From your Slack app's "OAuth & Permissions" page (starts with xoxb-)
SLACK_BOT_TOKEN=

# From "Basic Information" → App-Level Tokens, with connections:write (starts with xapp-)
SLACK_APP_TOKEN=

# From your Slack app's "Basic Information" page
SLACK_SIGNING_SECRET=

# From console.anthropic.com → API Keys (powers the Claude summaries)
ANTHROPIC_API_KEY=

# --- Retrieval via MCP server (the hackathon's "MCP server integration") ---
# A free Tavily key turns on MCP retrieval: Pulse attaches Tavily's remote MCP
# server to the Claude call and searches through it. Get one at app.tavily.com.
# Without this, Pulse falls back to Claude's built-in web_search tool.
TAVILY_API_KEY=

# Optional: point Pulse at any other remote (URL-based) search MCP server
# instead of Tavily. If set, this overrides TAVILY_API_KEY.
# MCP_SERVER_URL=
# MCP_SERVER_NAME=tavily
